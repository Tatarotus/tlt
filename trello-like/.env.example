# Database
DATABASE_URL=postgresql://sam:strongpassword@smre.run.place:5432/mydb

# Authentication
JWT_SECRET=super-secret-local-key-change-in-production

# ============================================================================
# AI Configuration (OpenAI-compatible endpoints) - REQUIRED
# ============================================================================

# Required: Your API key
AI_API_KEY=your-api-key-here

# Required: API endpoint(s) - can be multiple comma-separated for fallback
# Examples:
#   AI_API_URLS=https://api.sambanova.ai/v1/chat/completions
#   AI_API_URLS=http://localhost:11434/v1/chat/completions
#   AI_API_URLS=https://api.openai.com/v1/chat/completions,https://api.sambanova.ai/v1/chat/completions
AI_API_URLS=

# Optional: Single API endpoint (used if AI_API_URLS not set)
# (Use this OR AI_API_URLS, not both)
AI_API_URL=

# Required: Model(s) - can be multiple comma-separated for fallback
# Examples:
#   AI_MODELS=gpt-4o
#   AI_MODELS=Meta-Llama-3.3-70B-Instruct
#   AI_MODELS=qwen2.5:32b,llama3.1:70b
#   AI_MODELS=gpt-4o,gpt-4-turbo,claude-3-opus
AI_MODELS=

# ============================================================================
# Legacy / Fallback Variables (optional)
# ============================================================================
# If AI_API_KEY is not set, will fall back to these:
# OPENAI_API_KEY=
# OPENAI_API_URL=