{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "dryRunTimeoutMinutes": 5,
  "jest": {
    "enableFindRelatedTests": false,
    "projectType": "custom"
  },
  "mutate": [
    "lib/math-utils.ts",
    "lib/date-utils.ts",
    "lib/utils.ts"
  ],
  "mutator": {
    "excludedMutations": ["StringLiteral", "BlockStatement", "Regex"]
  },
  "reporters": ["clear-text", "progress", "html", "json"],
  "testRunner": "command",
  "commandRunner": {
    "command": "npx jest --config jest.config.js --runInBand --coverage=false"
  },
  "timeoutFactor": 1.5,
  "timeoutMS": 120000,
  "coverageAnalysis": "off",
  "ignorePatterns": ["**/node_modules/**"]
}
