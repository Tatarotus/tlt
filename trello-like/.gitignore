# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js Build Output
.next/
out/
build/
dist/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output
.rpt2_cache/
.eslintcache

# Environment Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# But commit .env.example
!.env.example

# Databases
# Ignore local SQLite files but keep schema/migrations
*.db
*.db-journal
*.sqlite
*.sqlite-journal
# Postgres specific temp files if any
.pgdata/

# OS and IDE artifacts
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.iws
*.iml
*.ipr
*.swp
*.swo
.project
.settings/
.classpath
.factorypath

# Bundlers / Tools
.parcel-cache
.cache
.turbo
.vercel
.netlify
.aider*
.gemini/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Docker
.docker
docker-compose.override.yml

# Bun
bun.lockb
# Note: we commit bun.lock (text-based) if used, but ignore binary lockb if present.

# Misc
*.pem
*.key
*.cert
tmp/
temp/
